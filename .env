# Core
ENV=development
PORT=5000

# Database
DB_PORT=5500
DB_NAME=docu_chat_postgres
DB_USER=docu_chat
DB_PASSWORD=secret
DATABASE_URL="postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_SECONDS=3600
REDIS_ENABLED=true

# PgAdmin
PGADMIN_PORT=8080
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Auth
ACCESS_TOKEN_SECRET=interchangeable
REFRESH_TOKEN_SECRET=interchangeable

# LLM
OPEN_API_KEY=interchangeable

# Search API Configuration
SEARCH_API_KEY=interchangeable
SEARCH_ENGINE_ID=interchangeable

# Error Tracking
SENTRY_DSN=interchangeable
